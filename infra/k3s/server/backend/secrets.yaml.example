apiVersion: v1
kind: Secret
metadata:
  name: backend-secrets
  namespace: blog-backend
  labels:
    app: backend
    tier: backend
type: Opaque
data:
  # Base64 encoded values - replace with your actual values
  # Encode with: echo -n 'your-value' | base64
  MONGODB_URL: bW9uZ29kYjovL2xvY2FsaG9zdDoyNzAxNw==  # mongodb://localhost:27017
  CHROMADB_HOST: bG9jYWxob3N0  # localhost
  GROQ_API_KEY: eW91ci1ncm9xLWFwaS1rZXk=  # your-groq-api-key
  JWT_SECRET_KEY: bG9jYWwtZGV2ZWxvcG1lbnQtc2VjcmV0LWtleQ==  # local-development-secret-key
