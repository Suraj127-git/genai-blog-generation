# Backend TLS Certificate Secret Example
# Use cert-manager to auto-generate or create manually

apiVersion: v1
kind: Secret
metadata:
  name: backend-tls-cert
  namespace: blog-backend
  labels:
    app: backend
    tier: backend
type: kubernetes.io/tls
data:
  # Base64 encoded TLS certificate and key
  # These will be auto-generated by cert-manager
  tls.crt: LS0tLS1CRUdJTi... # Placeholder
  tls.key: LS0tLS1CRUdJTi... # Placeholder

---
# To use cert-manager (recommended):
# 1. Install cert-manager
# 2. Create Certificate resource (see tls-certificate.yaml)
# 3. cert-manager will auto-create this secret

# To create manually:
# kubectl create secret tls backend-tls-cert \
#   --cert=path/to/tls.crt \
#   --key=path/to/tls.key \
#   --namespace=blog-backend
