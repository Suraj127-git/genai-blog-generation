# This is an EXAMPLE file. DO NOT commit actual secrets!
# Copy to secrets.yaml and update with real values

apiVersion: v1
kind: Secret
metadata:
  name: backend-secrets
  namespace: blog-backend
  labels:
    app: backend
    tier: backend
type: Opaque
stringData:
  # MongoDB Connection String (MongoDB Atlas or cloud MongoDB)
  # Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
  MONGODB_URL: "mongodb+srv://username:password@your-cluster.mongodb.net"
  
  # ChromaDB Host (ChromaDB Cloud or self-hosted)
  CHROMADB_HOST: "your-chromadb-host.com"
  
  # GroqAI API Key
  # Get from: https://console.groq.com/
  GROQ_API_KEY: "gsk_your_groq_api_key_here"
  
  # JWT Secret Key (min 32 characters)
  # Generate with: openssl rand -base64 32
  JWT_SECRET_KEY: "your-very-secure-random-jwt-secret-key-min-32-chars"

---
# To create from command line:
# kubectl create secret generic backend-secrets \
#   --from-literal=MONGODB_URL='mongodb+srv://user:pass@cluster.mongodb.net' \
#   --from-literal=CHROMADB_HOST='your-chromadb-host.com' \
#   --from-literal=GROQ_API_KEY='gsk_your_key' \
#   --from-literal=JWT_SECRET_KEY="$(openssl rand -base64 32)" \
#   --namespace=blog-backend
